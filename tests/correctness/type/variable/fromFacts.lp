phase_request(type_check,true).

variable_declare(v_bool_from_facts,fromFacts).
variable_domain(v_bool_from_facts,val(bool,true)).

variable_declare(v_int_from_facts,fromFacts).
variable_domain(v_int_from_facts,val(int,1)).

variable_declare(v_none_from_facts,fromFacts).
variable_domain(v_none_from_facts,val(none,none)).
