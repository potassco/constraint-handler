evaluated(eq,(operation(set_isin,(variable(execution_input(py_membership,"x")),(variable(pool),()))),(variable(execution_output(py_membership,"py_in")),())),val(bool,true))
evaluated(eq,(operation(set_notin,(variable(execution_input(py_membership,"x")),(variable(pool),()))),(variable(execution_output(py_membership,"py_not")),())),val(bool,true))
