    _fch_dynamic_expr_val(A1, _fch_type_bool_id, false),
    _fch_dynamic_expr_val(A2, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_leqv(ID, A1, A2),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, true),
    _fch_dynamic_expr_val(A2, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_leqv(ID, A1, A2),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, false),
    _fch_dynamic_expr_val(A2, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_leqv(ID, A1, _),
    _fch_dynamic_expr_val(A1, _fch_type_none_id, none).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_leqv(ID, _, A2),
    _fch_dynamic_expr_val(A2, _fch_type_none_id, none).

_fch_dynamic_leqv_prefix(ID, 0, true) :-
    _fch_op_leqv_variadic(ID, _).

_fch_dynamic_leqv_prefix(ID, NEXT, true) :-
    _fch_dynamic_leqv_prefix(ID, INDEX, true),
    _fch_op_leqv_arg(ID, NEXT, A),
    NEXT = INDEX + 1,
    _fch_dynamic_expr_val(A, _fch_type_bool_id, true).

_fch_dynamic_leqv_prefix(ID, NEXT, false) :-
    _fch_dynamic_leqv_prefix(ID, INDEX, true),
    _fch_op_leqv_arg(ID, NEXT, A),
    NEXT = INDEX + 1,
    _fch_dynamic_expr_val(A, _fch_type_bool_id, false).

_fch_dynamic_leqv_prefix(ID, NEXT, true) :-
    _fch_dynamic_leqv_prefix(ID, INDEX, false),
    _fch_op_leqv_arg(ID, NEXT, A),
    NEXT = INDEX + 1,
    _fch_dynamic_expr_val(A, _fch_type_bool_id, false).

_fch_dynamic_leqv_prefix(ID, NEXT, false) :-
    _fch_dynamic_leqv_prefix(ID, INDEX, false),
    _fch_op_leqv_arg(ID, NEXT, A),
    NEXT = INDEX + 1,
    _fch_dynamic_expr_val(A, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, VALUE) :-
    _fch_op_leqv_variadic(ID, LEN),
    LEN = #count { INDEX : _fch_op_leqv_arg(ID, INDEX, A), _fch_dynamic_expr_val(A, _fch_type_bool_id, _) },
    _fch_dynamic_leqv_prefix(ID, LEN, VALUE).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_leqv_variadic(ID, LEN),
    LEN > #count { INDEX : _fch_op_leqv_arg(ID, INDEX, A), _fch_dynamic_expr_val(A, _fch_type_bool_id, _) },
    0 < #count { INDEX : _fch_op_leqv_arg(ID, INDEX, A), _fch_dynamic_expr_val(A, _fch_type_none_id, none) }.

% =============================================================================
% LNOT
% =============================================================================

_fch_dynamic_expr_val(ID, _fch_type_bool_id, true) :-
    _fch_op_lnot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_lnot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_lnot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_none_id, none).

% =============================================================================
% SNOT
% =============================================================================

_fch_dynamic_expr_val(ID, _fch_type_bool_id, true) :-
    _fch_op_snot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_snot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_snot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_none_id, none).

% =============================================================================
% WNOT
% =============================================================================

_fch_dynamic_expr_val(ID, _fch_type_bool_id, true) :-
    _fch_op_wnot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, true) :-
    _fch_op_wnot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_none_id, none).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_wnot(ID, A1),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, true).

% =============================================================================
% LXOR
% =============================================================================

_fch_dynamic_expr_val(ID, _fch_type_bool_id, true) :-
    _fch_op_lxor(ID, A1, A2),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, true),
    _fch_dynamic_expr_val(A2, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, true) :-
    _fch_op_lxor(ID, A1, A2),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, false),
    _fch_dynamic_expr_val(A2, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_lxor(ID, A1, A2),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, true),
    _fch_dynamic_expr_val(A2, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_lxor(ID, A1, A2),
    _fch_dynamic_expr_val(A1, _fch_type_bool_id, false),
    _fch_dynamic_expr_val(A2, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_lxor(ID, A1, _),
    _fch_dynamic_expr_val(A1, _fch_type_none_id, none).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_lxor(ID, _, A2),
    _fch_dynamic_expr_val(A2, _fch_type_none_id, none).

_fch_dynamic_lxor_prefix(ID, 0, false) :-
    _fch_op_lxor_variadic(ID, _).

_fch_dynamic_lxor_prefix(ID, NEXT, false) :-
    _fch_dynamic_lxor_prefix(ID, INDEX, false),
    _fch_op_lxor_arg(ID, NEXT, A),
    NEXT = INDEX + 1,
    _fch_dynamic_expr_val(A, _fch_type_bool_id, false).

_fch_dynamic_lxor_prefix(ID, NEXT, true) :-
    _fch_dynamic_lxor_prefix(ID, INDEX, false),
    _fch_op_lxor_arg(ID, NEXT, A),
    NEXT = INDEX + 1,
    _fch_dynamic_expr_val(A, _fch_type_bool_id, true).

_fch_dynamic_lxor_prefix(ID, NEXT, true) :-
    _fch_dynamic_lxor_prefix(ID, INDEX, true),
    _fch_op_lxor_arg(ID, NEXT, A),
    NEXT = INDEX + 1,
    _fch_dynamic_expr_val(A, _fch_type_bool_id, false).

_fch_dynamic_lxor_prefix(ID, NEXT, false) :-
    _fch_dynamic_lxor_prefix(ID, INDEX, true),
    _fch_op_lxor_arg(ID, NEXT, A),
    NEXT = INDEX + 1,
    _fch_dynamic_expr_val(A, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, VALUE) :-
    _fch_op_lxor_variadic(ID, LEN),
    LEN = #count { INDEX : _fch_op_lxor_arg(ID, INDEX, A), _fch_dynamic_expr_val(A, _fch_type_bool_id, _) },
    _fch_dynamic_lxor_prefix(ID, LEN, VALUE).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_lxor_variadic(ID, LEN),
    LEN > #count { INDEX : _fch_op_lxor_arg(ID, INDEX, A), _fch_dynamic_expr_val(A, _fch_type_bool_id, _) },
    0 < #count { INDEX : _fch_op_lxor_arg(ID, INDEX, A), _fch_dynamic_expr_val(A, _fch_type_none_id, none) }.

% =============================================================================
% DISJ
% =============================================================================

_fch_dynamic_expr_val(ID, _fch_type_bool_id, true) :-
    _fch_op_disj_variadic(ID, _),
    _fch_op_disj_arg(ID, _, A),
    _fch_dynamic_expr_val(A, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_disj_variadic(ID, _),
    #false : _fch_op_disj_arg(ID, _, A), not _fch_dynamic_expr_val(A, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_disj_variadic(ID, _),
    _fch_op_disj_arg(ID, _, A),
    _fch_dynamic_expr_val(A, _fch_type_none_id, none),
    not _fch_dynamic_has_true(ID),
    not _fch_dynamic_has_false(ID).

% =============================================================================
% CONJ
% =============================================================================

_fch_dynamic_expr_val(ID, _fch_type_bool_id, false) :-
    _fch_op_conj_variadic(ID, _),
    _fch_op_conj_arg(ID, _, A),
    _fch_dynamic_expr_val(A, _fch_type_bool_id, false).

_fch_dynamic_expr_val(ID, _fch_type_bool_id, true) :-
    _fch_op_conj_variadic(ID, _),
    #false : _fch_op_conj_arg(ID, _, A), not _fch_dynamic_expr_val(A, _fch_type_bool_id, true).

_fch_dynamic_expr_val(ID, _fch_type_none_id, none) :-
    _fch_op_conj_variadic(ID, _),
    _fch_op_conj_arg(ID, _, A),
    _fch_dynamic_expr_val(A, _fch_type_none_id, none),
    not _fch_dynamic_has_true(ID),
    not _fch_dynamic_has_false(ID).
